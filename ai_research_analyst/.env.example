# ─────────────────────────────────────────────────────────────
#  AI Research Analyst Agent — Environment Variables
#  Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────

# OpenAI — used for planner, critic, optimizer, searcher
OPENAI_API_KEY=sk-...

# Anthropic — used for summarizer and report writer (multi-model)
ANTHROPIC_API_KEY=sk-ant-...

# Serper.dev — web search (get free key at https://serper.dev)
SERPER_API_KEY=...

# Pushover — push notifications (https://pushover.net)
PUSHOVER_USER_KEY=...
PUSHOVER_APP_TOKEN=...

# LangSmith — tracing and observability (https://smith.langchain.com)
LANGCHAIN_API_KEY=...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-research-analyst
